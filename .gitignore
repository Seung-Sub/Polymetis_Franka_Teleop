# Data + artefacts
data/
calibration_results/
*.zarr/
*.zarr.zip
*.mp4

# Stray junk: if a shell command substitution like ``data/session_$(date ...)``
# evaluates to an empty timestamp (broken paste / mangled line continuation),
# the demo can land its output at the repo root with a literal-space name.
# Match any top-level path starting with whitespace so the next accident
# doesn't get committed by a hurried ``git add -A``.
/ *

# Python build/install
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Logs
*.log
logs/
nohup.out
